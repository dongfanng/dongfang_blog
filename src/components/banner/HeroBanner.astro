---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';
import { siteConfig } from '@/config/site';

const imageFiles = import.meta.glob<ImageMetadata>(
  '../../assets/images/*.{jpg,jpeg,png,webp,avif}',
  { import: 'default' }
);

const imageName = siteConfig.home.banner.image;
const imageLoader = imageFiles[`../../assets/images/${imageName}`];
if (!imageLoader) {
  throw new Error(`Banner image not found: ${imageName} (请在 src/assets/images/ 下放置)`);
}
const image = await imageLoader();

const { overlay, overlayOpacity, height } = siteConfig.home.banner;
---

<div class="relative overflow-hidden" style={{ height }}>
  <div class="absolute inset-0 [&>picture]:h-full [&>picture]:w-full [&>picture>img]:h-full [&>picture>img]:w-full [&>picture>img]:object-cover">
    <Picture
      src={image}
      alt=""
      widths={[480, 960, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  {overlay && (
    <div class="absolute inset-0 bg-black" style={{ opacity: overlayOpacity }} />
  )}

  <div class="relative z-10 h-full flex items-center justify-center">
    <div class="text-center text-white px-4">
      <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-3xl font-bold border-2 border-white/30 shadow-lg">
        {siteConfig.home.avatarText}
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4 drop-shadow-lg">
        {siteConfig.name}
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto drop-shadow-md">
        {siteConfig.description}
      </p>
    </div>
  </div>
</div>
