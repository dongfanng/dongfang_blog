---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** 背景图片（ImageMetadata，由 Astro 优化处理） */
  image: ImageMetadata;
  /** 是否显示遮罩 */
  overlay?: boolean;
  /** 遮罩透明度 (0-1) */
  overlayOpacity?: number;
  /** 横幅高度 */
  height?: string;
  /** 自定义类名 */
  class?: string;
}

const {
  image,
  overlay = true,
  overlayOpacity = 0.5,
  height = '500px',
  class: className,
} = Astro.props;
---

<div
  class={`relative overflow-hidden ${className || ''}`}
  style={{ height }}
>
  <!-- 背景图片（响应式 + AVIF/WebP 自动转换） -->
  <div class="absolute inset-0 [&>picture]:h-full [&>picture]:w-full [&>picture>img]:h-full [&>picture>img]:w-full [&>picture>img]:object-cover">
    <Picture
      src={image}
      alt=""
      widths={[480, 960, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- 遮罩层 -->
  {overlay && (
    <div
      class="absolute inset-0 bg-black"
      style={{ opacity: overlayOpacity }}
    />
  )}

  <!-- 内容插槽 -->
  <div class="relative z-10 h-full">
    <slot />
  </div>
</div>
