---
interface Props {
  headings: { depth: number; text: string; slug: string }[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <nav class="toc sticky top-24">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">目录</h3>
    <ul class="space-y-2 text-sm">
      {headings.map((heading) => (
        <li
          class={`toc-item`}
          style={{ paddingLeft: `${(heading.depth - 2) * 12}px` }}
        >
          <a
            href={`#${heading.slug}`}
            class="block text-gray-600 dark:text-gray-400 hover:text-primary-500 dark:hover:text-primary-400 transition-colors truncate"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
