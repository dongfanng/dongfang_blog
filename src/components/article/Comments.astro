---
interface Props {
  repo: string;
  repoId: string;
  category: string;
  categoryId: string;
}

const { repo, repoId, category, categoryId } = Astro.props;
---

<section id="comments" class="mt-16">
  <h2 class="text-2xl font-bold mb-6">评论</h2>
  <div class="giscus" data-repo={repo} data-repo-id={repoId} data-category={category} data-category-id={categoryId} data-mapping="pathname" data-strict="0" data-reactions-enabled="1" data-emit-metadata="0" data-input-position="top" data-theme="preferred_color_scheme" data-lang="zh-CN" data-loading="lazy"></div>
  <script is:inline src="https://giscus.app/client.js" async></script>
</section>
