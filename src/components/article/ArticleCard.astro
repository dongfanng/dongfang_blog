---
import type { BlogPost } from '@/utils/posts';
import { getReadingTime } from '@/utils/posts';
import { formatDate } from '@/utils/date';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags, sticky } = post.data;
const readingTime = getReadingTime(post.body);
---

<article class="group">
  <a href={`/blog/${post.slug}`} class="block">
    <div class="p-6 rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-lg dark:hover:shadow-xl transition-all duration-200">
      <div class="flex items-start justify-between gap-4 mb-3">
        <div class="flex items-center gap-3">
          {sticky > 0 && (
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200">
              置顶
            </span>
          )}
          <span class="text-sm text-gray-500 dark:text-gray-400">
            {formatDate(pubDate)}
          </span>
          <span class="text-sm text-gray-400 dark:text-gray-500">·</span>
          <span class="text-sm text-gray-500 dark:text-gray-400">
            {readingTime} 分钟
          </span>
        </div>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 shrink-0">
          {category}
        </span>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary-500 dark:group-hover:text-primary-400 mb-2 transition-colors">
        {title}
      </h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">
        {description}
      </p>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
            #{tag}
          </span>
        ))}
      </div>
    </div>
  </a>
</article>
