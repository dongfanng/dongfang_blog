---
import { siteConfig } from '@/config/site';
import VueSiteStats from '../stats/VueSiteStats.vue';
import { Icon } from 'astro-icon/components';
---

<footer class="border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="container-prose py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3 text-gray-600 dark:text-gray-400">
        <span>© {new Date().getFullYear()} {siteConfig.name}</span>
        <span class="hidden sm:inline">·</span>
        <VueSiteStats client:visible />
      </div>
      <div class="flex items-center gap-4">
        <a href={siteConfig.social.rss} class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          <Icon name="lucide:rss" class="w-5 h-5" />
        </a>
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          <Icon name="lucide:github" class="w-5 h-5" />
        </a>
      </div>
    </div>
  </div>
</footer>
