---
export interface Props {
  year: string;
  count: number;
}

const { year, count } = Astro.props;
---

<section>
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 sticky top-20 bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm py-2 z-10">
    {year} 年 ({count})
  </h2>
  <ul class="space-y-3 relative pl-6 ml-2">
    <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>
    <slot />
  </ul>
</section>
