---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/article/ArticleCard.astro';
import { sortPosts, getCategories, getTags } from '@/utils/posts';

const posts = await getCollection('blog');
const sortedPosts = sortPosts(posts);
const categories = getCategories(posts);
const tags = getTags(posts);
---

<BaseLayout title="文章">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">文章</h1>
      <p class="text-gray-600 dark:text-gray-400">共 {sortedPosts.length} 篇文章</p>
    </header>

    <!-- 筛选器 -->
    <div class="mb-8 flex flex-wrap gap-4">
      <details class="group">
        <summary class="cursor-pointer px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
          分类
        </summary>
        <div class="mt-2 p-4 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
          <div class="flex flex-wrap gap-2">
            {categories.map((category) => (
              <a
                href={`/blog/categories/${category}`}
                class="px-3 py-1 rounded-full text-sm bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
              >
                {category}
              </a>
            ))}
          </div>
        </div>
      </details>
      <details class="group">
        <summary class="cursor-pointer px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
          标签
        </summary>
        <div class="mt-2 p-4 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/blog/tags/${tag}`}
                class="px-3 py-1 rounded-full text-sm bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </details>
      <a href="/archive" class="px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
        归档
      </a>
    </div>

    <!-- 文章列表 -->
    <div class="grid gap-6">
      {sortedPosts.map((post) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </div>
</BaseLayout>
