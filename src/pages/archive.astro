---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { sortPosts, groupPostsByYear } from '@/utils/posts';
import { formatDate } from '@/utils/date';

const posts = await getCollection('blog');
const sortedPosts = sortPosts(posts);
const postsByYear = groupPostsByYear(sortedPosts);
---

<BaseLayout title="归档">
  <div class="container-prose py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">归档</h1>
      <p class="text-gray-600 dark:text-gray-400">共 {sortedPosts.length} 篇文章</p>
    </header>

    <div class="space-y-8">
      {Array.from(postsByYear.entries()).map(([year, yearPosts]) => (
        <section>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 sticky top-20 bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm py-2 z-10">
            {year} 年 ({yearPosts.length})
          </h2>
          <ul class="space-y-3 ml-2 border-l-2 border-gray-200 dark:border-gray-700">
            {yearPosts.map((post) => (
              <li class="flex gap-3">
                <div class="flex flex-col items-center">
                  <div class="w-3 h-3 mt-2 rounded-full bg-primary-500 dark:bg-primary-400 border-2 border-white dark:border-gray-900 -ml-[7px] z-10 shrink-0"></div>
                </div>
                <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-1">
                  <span class="text-sm text-gray-500 dark:text-gray-400 shrink-0">
                    {formatDate(post.data.pubDate)}
                  </span>
                  <a
                    href={`/blog/${post.slug}`}
                    class="text-gray-900 dark:text-white hover:text-primary-500 dark:hover:text-primary-400 transition-colors"
                  >
                    {post.data.title}
                  </a>
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
