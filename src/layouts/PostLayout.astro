---
import BaseLayout from './BaseLayout.astro';
import { formatDate, formatDateTime } from '@/utils/date';
import { siteConfig } from '@/config/site';
import { Icon } from 'astro-icon/components';
import TableOfContents from '@/components/article/TableOfContents.astro';
import VueReadingProgress from '@/components/article/VueReadingProgress.vue';
import VueBackToTop from '@/components/ui/VueBackToTop.vue';
import VueCodeCopy from '@/components/article/VueCodeCopy.vue';
import VueLightbox from '@/components/article/VueLightbox.vue';
import VueTocHighlight from '@/components/article/VueTocHighlight.vue';
import type { BlogPost } from '@/utils/posts';
import { getReadingTime } from '@/utils/posts';

interface Props {
  post: BlogPost;
  headings?: { depth: number; text: string; slug: string }[];
  prev?: BlogPost | null;
  next?: BlogPost | null;
  related?: BlogPost[];
  lastModified?: string;
}

const { post, headings = [], prev, next, related, lastModified } = Astro.props;
const { title, description, pubDate, category, tags, image } = post.data;
const updatedDate = post.data.updatedDate || (lastModified ? new Date(lastModified) : null);
const readingTime = getReadingTime(post.body);
---

<BaseLayout title={title} description={description} image={image} pubDate={pubDate} updatedDate={updatedDate ?? undefined} category={category} tags={tags}>
  <VueReadingProgress client:visible />
  <VueCodeCopy client:load />
  <VueLightbox client:idle />
  <VueTocHighlight client:idle />

  <div class="container-prose py-8">
    <article>
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <a href={`/blog/categories/${category}`} class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300">
          {category}
        </a>
        <time class="text-sm text-gray-500 dark:text-gray-400">
          发布于 {formatDate(pubDate)}
        </time>
        <span class="text-sm text-gray-400 dark:text-gray-500">·</span>
        <span class="text-sm text-gray-500 dark:text-gray-400">
          约 {readingTime} 分钟阅读
        </span>
        {updatedDate && (
          <time class="text-sm text-gray-500 dark:text-gray-400">
            · 更新于 {formatDate(updatedDate)}
          </time>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {title}
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
        {description}
      </p>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a
            href={`/blog/tags/${tag}`}
            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <div class="prose dark:prose-invert max-w-none">
      <slot />
    </div>

    <div class="mt-6 flex items-center justify-between text-sm text-gray-500 dark:text-gray-400">
      <a
        href={`${siteConfig.social.github}/edit/main/src/content/blog/${post.slug}.md`}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-primary-500 dark:hover:text-primary-400 transition-colors inline-flex items-center gap-1.5"
      >
        <Icon name="lucide:pencil" class="w-4 h-4" />
        在 GitHub 上编辑此页
      </a>
      <span class="inline-flex items-center gap-1.5">
        <Icon name="lucide:clock" class="w-4 h-4" />
        最后更新于: {formatDateTime(updatedDate || pubDate)}
      </span>
    </div>

    {(prev || next) && (
      <nav class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {prev && (
            <a href={`/blog/${prev.slug}`} class="group p-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
              <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">← 上一篇</div>
              <div class="font-medium text-gray-900 dark:text-white group-hover:text-primary-500 dark:group-hover:text-primary-400 transition-colors">
                {prev.data.title}
              </div>
            </a>
          )}
          {next && (
            <a href={`/blog/${next.slug}`} class={`group p-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors text-right ${prev ? '' : 'md:col-start-2'}`}>
              <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">下一篇 &gt;</div>
              <div class="font-medium text-gray-900 dark:text-white group-hover:text-primary-500 dark:group-hover:text-primary-400 transition-colors">
                {next.data.title}
              </div>
            </a>
          )}
        </div>
      </nav>
    )}

    {related && related.length > 0 && (
      <section class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">相关文章</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {related.map((p) => (
            <a
              href={`/blog/${p.slug}`}
              class="group p-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors"
            >
              <div class="font-medium text-gray-900 dark:text-white group-hover:text-primary-500 dark:group-hover:text-primary-400 transition-colors line-clamp-2">
                {p.data.title}
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                {formatDate(p.data.pubDate)}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
    </article>
  </div>

  {headings.length > 0 && (
    <aside class="hidden 2xl:block fixed top-24 z-30 w-64" style="left: calc(50% + 30rem);">
      <div class="max-h-[calc(100vh-6rem)] overflow-y-auto">
        <TableOfContents headings={headings} />
      </div>
    </aside>
  )}

  <VueBackToTop client:idle />
</BaseLayout>
