---
import BaseHead from '@/components/layout/BaseHead.astro';
import VueHeader from '@/components/layout/VueHeader.vue';
import Footer from '@/components/layout/Footer.astro';
import VueClickEffect from '@/components/ui/VueClickEffect.vue';
import VueConsoleEasterEgg from '@/components/ui/VueConsoleEasterEgg.vue';
import '@/styles/global.css';
import type { SEOProps } from '@/utils/seo';

interface Props extends SEOProps {}
---

<!DOCTYPE html>
<html lang="zh-CN" transition:animate="none">
  <BaseHead {...Astro.props} />
  <body class="min-h-screen flex flex-col pt-16">
    <VueHeader client:load transition:persist="site-header" />
    <div class="flex flex-1 flex-col" transition:name="page-content">
      <main class="flex-1 flex flex-col">
        <slot />
      </main>
    </div>
    <Footer />
    <VueClickEffect client:load transition:persist="click-effect" />
    <VueConsoleEasterEgg client:load transition:persist="console-egg" />
  </body>
</html>

{import.meta.env.PROD && (
<script is:inline>
  if (!window.pagefind) {
    async function loadPagefind() {
      try {
        const pagefind = await import('/pagefind/pagefind.js');
        await pagefind.options({ "excerptLength": 20 });
        window.pagefind = pagefind;
        window.dispatchEvent(new Event('pagefindready'));
      } catch (error) {
        console.warn("Pagefind failed to load:", error);
        window.dispatchEvent(new Event('pagefindloaderror'));
      }
    }
    loadPagefind();
  }
</script>
)}
